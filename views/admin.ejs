<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>Admin Panel - Transfer Gateway</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>

<div class="card" style="margin-top: 20px;">
  <h2>God Mode Dashboard</h2>
  <div class="sub">Live Server Management</div>

  <div class="admin-list" id="adminUserList"></div>
  <button class="btn btn-ghost" style="margin-top: 0; margin-bottom: 12px;" onclick="adminPrepareNewUser()">+ Create New User</button>

  <div style="background: #f8fafc; padding: 16px; border-radius: 12px; border: 1px solid var(--border);">
    <h3 style="margin: 0 0 14px; font-size: 16px; color: #0f172a;" id="adminFormTitle">Create New User</h3>
    
    <div style="display: flex; gap: 10px;">
      <div class="field" style="flex: 1;">
        <label>Username / Email</label>
        <input id="admUsername" placeholder="e.g. user@email.com">
      </div>
      <div class="field" style="flex: 1;">
        <label>Password</label>
        <input id="admPassword" placeholder="Set user password">
      </div>
    </div>

    <div style="display: flex; gap: 10px;">
      <div class="field" style="flex: 1;">
        <label>Network / Bank Name</label>
        <input id="admNetwork" placeholder="e.g. Barclays Corporate (UK)">
      </div>
      <div class="field" style="flex: 1;">
        <label>Status Code (If Declined)</label>
        <input id="admStatusCode" placeholder="e.g. ERR_LIQUIDITY_HOLD">
      </div>
    </div>

    <div style="display: flex; gap: 10px;">
      <div class="field" style="flex: 1;">
        <label>Region Flow (Sets Currency & Banks)</label>
        <select id="admRegion">
          <option value="uk">UK (GBP £ / Sort Code)</option>
          <option value="global">Global (EUR € / IBAN)</option>
        </select>
      </div>
      <div class="field" style="flex: 1;">
        <label>Final Outcome</label>
        <select id="admOutcome">
          <option value="success">✅ Success (Approved)</option>
          <option value="decline">❌ Decline (Failed)</option>
        </select>
      </div>
    </div>

    <div style="display: flex; gap: 10px;">
      <div class="field" style="flex: 1;">
        <label>Amount (Numbers only)</label>
        <input id="admAmount" type="number" step="0.01" placeholder="e.g. 50000">
      </div>
      <div class="field" style="flex: 1;">
        <label>Deposit Pct (%)</label>
        <input id="admDeposit" type="number" step="1" placeholder="e.g. 10">
      </div>
    </div>

    <div class="field">
      <label>Reason Message</label>
      <textarea id="admReason" rows="3" placeholder="Reason for success or decline..."></textarea>
    </div>

    <div style="display: flex; gap: 10px;">
      <div class="field" style="flex: 1;">
        <label>Regulation Reference</label>
        <input id="admRegRef" placeholder="e.g. Regulation 41(2)">
      </div>
      <div class="field" style="flex: 1;">
        <label>Regulation Title</label>
        <input id="admRegTitle" placeholder="e.g. Framework">
      </div>
    </div>

    <button class="btn btn-primary" onclick="adminSaveUser()">💾 Save User to Server</button>
    <button class="btn btn-danger" id="admDeleteBtn" onclick="adminDeleteUser()" style="display: none;">🗑️ Delete User</button>
  </div>

  <button class="btn btn-dark" onclick="window.location.href='/'">Log Out (Back to Login)</button>
</div>

<script>
  let currentAdminEditingUser = null;
  let allUsers = {};

  async function loadUsers() {
    try {
      const res = await fetch('/api/users');
      allUsers = await res.json();
      renderAdminList();
    } catch (err) { alert("Failed to load users."); }
  }

  function renderAdminList() {
    const list = document.getElementById("adminUserList");
    list.innerHTML = "";
    Object.keys(allUsers).forEach(username => {
      const user = allUsers[username];
      const div = document.createElement("div");
      div.className = "admin-list-item";
      const icon = user.outcome === "success" ? "✅" : "❌";
      const regionFlag = user.region === "uk" ? "🇬🇧" : "🌍";
      div.textContent = `${icon} ${regionFlag} ${username} - ${user.amount}`;
      div.onclick = () => adminLoadUser(username, div);
      list.appendChild(div);
    });
  }

  function adminPrepareNewUser() {
    currentAdminEditingUser = null;
    document.getElementById("adminFormTitle").textContent = "Create New User";
    document.getElementById("admUsername").value = "";
    document.getElementById("admUsername").disabled = false;
    document.getElementById("admPassword").value = ""; 
    document.getElementById("admNetwork").value = "Easy Payment And Finance Bank (EUSIM)"; 
    document.getElementById("admStatusCode").value = "ERR_LIQUIDITY_HOLD"; 
    document.getElementById("admRegion").value = "uk";
    document.getElementById("admOutcome").value = "success";
    document.getElementById("admAmount").value = "";
    document.getElementById("admDeposit").value = "";
    document.getElementById("admReason").value = "";
    document.getElementById("admRegRef").value = "";
    document.getElementById("admRegTitle").value = "";
    document.getElementById("admDeleteBtn").style.display = "none";
    document.querySelectorAll(".admin-list-item").forEach(el => el.classList.remove("selected"));
  }

  function adminLoadUser(username, element) {
    document.querySelectorAll(".admin-list-item").forEach(el => el.classList.remove("selected"));
    if (element) element.classList.add("selected");

    const data = allUsers[username];
    currentAdminEditingUser = username;
    document.getElementById("adminFormTitle").textContent = "Edit User: " + username;
    document.getElementById("admUsername").value = username;
    document.getElementById("admUsername").disabled = true; 
    document.getElementById("admPassword").value = data.password || ""; 
    document.getElementById("admNetwork").value = data.networkName || "Easy Payment And Finance Bank (EUSIM)"; 
    document.getElementById("admStatusCode").value = data.statusCode || "ERR_LIQUIDITY_HOLD"; 
    document.getElementById("admRegion").value = data.region || "uk";
    document.getElementById("admOutcome").value = data.outcome || "success";
    document.getElementById("admAmount").value = data.amount || 0;
    document.getElementById("admDeposit").value = data.depositPct || 0;
    document.getElementById("admReason").value = data.reason || "";
    document.getElementById("admRegRef").value = data.regulationRef || "";
    document.getElementById("admRegTitle").value = data.regulationTitle || "";
    document.getElementById("admDeleteBtn").style.display = "block";
  }

  async function adminSaveUser() {
    const username = document.getElementById("admUsername").value.trim().toLowerCase();
    if (!username) return alert("Username cannot be empty");

    const userData = {
      password: document.getElementById("admPassword").value.trim(),
      networkName: document.getElementById("admNetwork").value.trim(),
      statusCode: document.getElementById("admStatusCode").value.trim().toUpperCase() || "ERR_LIQUIDITY_HOLD",
      region: document.getElementById("admRegion").value,
      outcome: document.getElementById("admOutcome").value,
      amount: Number(document.getElementById("admAmount").value) || 0,
      depositPct: Number(document.getElementById("admDeposit").value) || 0,
      reason: document.getElementById("admReason").value,
      regulationRef: document.getElementById("admRegRef").value,
      regulationTitle: document.getElementById("admRegTitle").value
    };

    if (!userData.password) return alert("Please set a password.");
    if (!userData.networkName) return alert("Please set a network name.");

    try {
      await fetch('/api/users', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username, userData })
      });
      alert("User saved successfully!");
      await loadUsers();
      adminPrepareNewUser();
    } catch (err) { alert("Failed to save user."); }
  }

  async function adminDeleteUser() {
    if (!currentAdminEditingUser) return;
    if (confirm("Delete this user permanently?")) {
      try {
        await fetch(`/api/users/${currentAdminEditingUser}`, { method: 'DELETE' });
        await loadUsers();
        adminPrepareNewUser();
      } catch (err) { alert("Failed to delete user."); }
    }
  }

  loadUsers();
</script>
</body>
</html>